# Redline PDF Editor - Environment Variables
# Copy this file to .env.local and customize as needed

# Feature Flags
# Set to 'false' to disable specific features

# Enable automatic session saving to IndexedDB (default: true)
VITE_ENABLE_AUTO_SAVE=true

# Enable keyboard shortcuts like Ctrl+Z, Ctrl+S, etc. (default: true)
VITE_ENABLE_SHORTCUTS=true

# Enable touch gestures like pinch-to-zoom (default: true)
VITE_ENABLE_TOUCH=true

# Enable session restore from IndexedDB on page load (default: true)
VITE_ENABLE_RESTORE=true

# Resource Limits
# Configure maximum file sizes and page counts

# Maximum PDF file size in megabytes (default: 50)
VITE_MAX_PDF_SIZE_MB=50

# Maximum image file size in megabytes (default: 10)
VITE_MAX_IMAGE_SIZE_MB=10

# Maximum number of PDF pages to allow (default: 500)
VITE_MAX_PDF_PAGES=500
